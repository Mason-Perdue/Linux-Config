<?xml version="1.0" ?>

<labwc_config>

  <keyboard>
    <default />
    <keybind key="W-space"><action name="Execute" command="fuzzel" /></keybind>
    <keybind key="W-q"><action name="Close" /></keybind>
    <keybind key="W-p"><action name="Execute" command="~/.config/labwc/scripts/screenshot.sh" /></keybind>
    <keybind key="W-l"><action name="Execute" command="~/.config/labwc/scripts/lock_suspend.sh" /></keybind>
    <keybind key="W-S-l"><action name="Execute" command="systemctl poweroff" /></keybind>
    <keybind key="XF86_AudioLowerVolume"><action name="Execute" command="pamixer --decrease 5" /></keybind>
    <keybind key="XF86_AudioRaiseVolume"><action name="Execute" command="pamixer --unmute --increase 5" /></keybind>
    <keybind key="XF86_AudioMute"><action name="Execute" command="pamixer --set-volume 0" /></keybind>
    <keybind key="XF86MonBrightnessUp"><action name="Execute" command="brightnessctl --class=backlight set 10%+" /></keybind>
    <keybind key="XF86MonBrightnessDown"><action name="Execute" command="brightnessctl --class=backlight set 10%-" /></keybind>
  </keyboard>

</labwc_config>
